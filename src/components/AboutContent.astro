---
import { getEntry } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import ContactLinks from "@components/ContactLinks.astro";

const about = await getEntry("about", "profile");
if (!about) {
  throw new Error("Missing about/profile.md content entry");
}

const markdownProcessor = await createMarkdownProcessor();
const summary = await Promise.all(
  about.data.summary.map(async (line) => {
    const { code } = await markdownProcessor.render(line);
    return code.trim().replace(/^<p>/, "").replace(/<\/p>$/, "");
  })
);
---

<div class="container page">
  <section class="hero">
    <p class="eyebrow">{about.data.location}</p>
    <h1>{about.data.name}</h1>
    {summary.map((line) => <p set:html={line} />)}
    <ContactLinks contacts={about.data.contacts} />
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Interests</h2>
    </div>
    <ul class="tag-list large-tags">
      {about.data.interests.map((interest) => <li>{interest}</li>)}
    </ul>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Skills</h2>
    </div>
    <div class="skills-grid">
      {
        about.data.skills.map((skillGroup) => (
          <article class="skill-group">
            <h3>{skillGroup.group}</h3>
            <ul class="tag-list">
              {skillGroup.items.map((skill) => <li>{skill}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
</div>

<style lang="scss">
  .large-tags li {
    padding: 0.4rem 0.7rem;
    font-size: 0.95rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 1rem;
  }

  .skill-group {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .skill-group h3 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }
</style>
