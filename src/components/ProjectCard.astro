---
import { render } from "astro:content";
import { ExternalLink } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await render(project);
---

<article class="project-card card">
  <div class="project-meta">
    <div>
      <span>{project.data.year}</span>
      <span>{project.data.context}</span>
    </div>
    <strong>{project.data.role}</strong>
  </div>
  <h2>
    <a href={project.data.url} target="_blank" rel="noreferrer">
      {project.data.projectName}
      <ExternalLink size={17} aria-hidden="true" />
    </a>
  </h2>
  <div class="divider" aria-hidden="true"></div>
  <div class="description">
    <Content />
  </div>
  <ul class="tag-list" aria-label={`Technologies used in ${project.data.projectName}`}>
    {project.data.technologies.map((technology) => <li>{technology}</li>)}
  </ul>
</article>

<style lang="scss">
  .project-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1.25rem;
  }

  .project-meta {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .project-meta div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-meta strong {
    flex: 0 0 auto;
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.4;
    text-align: right;
  }

  h2 {
    margin: 0.65rem 0 0.55rem;
    font-size: 1.18rem;
    line-height: 1.2;
  }

  h2 a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
  }

  .divider {
    width: 100%;
    height: 1px;
    margin-bottom: 0.9rem;
    background: var(--border);
  }

  .description {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .description :global(p) {
    margin-top: 0;
  }

  .tag-list {
    margin-top: auto;
    padding-top: 0.8rem;
  }

  @media (max-width: 420px) {
    .project-meta {
      align-items: center;
    }
  }
</style>
